# Pomerium Zero local data-plane bootstrap token. Never commit the real value.
POMERIUM_ZERO_TOKEN=
POMERIUM_IMAGE_TAG=v0.32.7

# The same service-account JWT is used against both routes.
POMERIUM_SERVICE_ACCOUNT_TOKEN=
POMERIUM_SERVICE_ACCOUNT_USER_ID=pitchloop-agent

# Route URLs created from infra/pomerium/route-blueprint.yaml.
POMERIUM_DENIED_URL=https://pitchloop-denied.YOUR_STARTER_DOMAIN.pomerium.app/authorize-observation
POMERIUM_ALLOWED_URL=https://pitchloop-allowed.YOUR_STARTER_DOMAIN.pomerium.app/authorize-observation

PITCHLOOP_RUN_ID=demo-001
PITCHLOOP_RUN_DIR=runs/demo-001
